{
  "info": {
    "_postman_id": "a3d8f1c2-5b6e-4f7a-9c1d-8e2b4a6f9d10",
    "name": "Task Tracker API",
    "description": "Task Tracker backend API (Spring Boot). Covers auth (register/login), task CRUD with pagination/filtering, and RBAC (User vs Admin).\n\nImport the accompanying \"Task Tracker - Local\" environment and select it before running requests.\n\nThe folders are ordered to be run top-to-bottom with 'Run collection': Auth (registers both users and logs in as the seeded Admin) → Tasks (as User) (creates the task used throughout) → Validation & RBAC Examples (including a 403 check that needs the task to still exist) → Tasks (as Admin) (ends by deleting the task). Deletion is deliberately the very last request in the collection so earlier folders always have a live {{taskId}} to work with.\n\nReal-time updates are broadcast over STOMP-over-WebSocket at `{{baseUrl}}/ws` (topics `/topic/tasks` and `/topic/tasks/deleted`) and aren't exercised by this REST collection — connect with a STOMP/SockJS client to observe them, or use the frontend app.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "userToken", "value": "", "type": "string" },
    { "key": "otherUserToken", "value": "", "type": "string" },
    { "key": "adminToken", "value": "", "type": "string" },
    { "key": "taskId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.test('Response has a token', function () { pm.expect(body.data.token).to.be.a('string'); });",
                  "if (body.success) { pm.collectionVariables.set('userToken', body.data.token); }"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{userUsername}}\",\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Creates a new account. Registration always assigns the USER role — there is no public sign-up path to Admin (see the root README's Assumptions section)."
          }
        },
        {
          "name": "Register Second User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "if (body.success) { pm.collectionVariables.set('otherUserToken', body.data.token); }"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{otherUserUsername}}\",\n  \"email\": \"{{otherUserEmail}}\",\n  \"password\": \"{{otherUserPassword}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "A second, independent account used to demonstrate RBAC (a non-owner being forbidden from another user's task) in the Validation & RBAC Examples folder."
          }
        },
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "if (body.success) { pm.collectionVariables.set('userToken', body.data.token); }"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Use this instead of Register once the user already exists (Register returns 400 on a duplicate email)."
          }
        },
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.test('Role is ADMIN', function () { pm.expect(body.data.role).to.eql('ADMIN'); });",
                  "if (body.success) { pm.collectionVariables.set('adminToken', body.data.token); }"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Logs in as the default Admin account seeded automatically on backend startup (AdminSeeder)."
          }
        }
      ]
    },
    {
      "name": "Tasks (as User)",
      "item": [
        {
          "name": "Create Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.test('Status defaults are respected', function () { pm.expect(body.data.status).to.eql('TODO'); });",
                  "if (body.success) { pm.collectionVariables.set('taskId', body.data.id); }"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{userToken}}", "type": "string" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Write Postman docs\",\n  \"description\": \"Document all implemented endpoints\",\n  \"status\": \"TODO\",\n  \"dueDate\": \"2026-08-01\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/tasks",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks"]
            },
            "description": "Creates a task owned by the authenticated user. `status` is optional and defaults to TODO."
          }
        },
        {
          "name": "Get Task By Id",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{userToken}}", "type": "string" }] },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/tasks/{{taskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks", "{{taskId}}"]
            },
            "description": "Returns 200 if the caller owns the task (or is Admin), 403 otherwise."
          }
        },
        {
          "name": "List My Tasks",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{userToken}}", "type": "string" }] },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/tasks?page=0&size=10&sortBy=createdAt&sortDir=desc",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" },
                { "key": "sortBy", "value": "createdAt" },
                { "key": "sortDir", "value": "desc" },
                { "key": "status", "value": "TODO", "disabled": true },
                { "key": "ownerId", "value": "1", "disabled": true }
              ]
            },
            "description": "Paginated list, scoped to the caller's own tasks (regular users can't see others' tasks regardless of the `ownerId` param). Enable the `status`/`ownerId` query params to filter."
          }
        },
        {
          "name": "List My Tasks - Filter by Status",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{userToken}}", "type": "string" }] },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/tasks?status=TODO&page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks"],
              "query": [
                { "key": "status", "value": "TODO" },
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" }
              ]
            },
            "description": "`status` accepts TODO, IN_PROGRESS, or DONE."
          }
        },
        {
          "name": "Update Task",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{userToken}}", "type": "string" }] },
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Write Postman docs (updated)\",\n  \"description\": \"Document all implemented endpoints\",\n  \"status\": \"IN_PROGRESS\",\n  \"dueDate\": \"2026-08-05\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/tasks/{{taskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks", "{{taskId}}"]
            },
            "description": "Full update (all fields required, matching Create Task's validation). Returns 403 if the caller doesn't own the task and isn't Admin."
          }
        }
      ]
    },
    {
      "name": "Validation & RBAC Examples",
      "item": [
        {
          "name": "Register - Duplicate Email (400)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"someoneelse\",\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"password123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Run 'Register User' first so this email already exists. Expect 400 with message \"Email already registered\"."
          }
        },
        {
          "name": "Create Task - Missing Title (400)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{userToken}}", "type": "string" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"No title provided\",\n  \"dueDate\": \"2026-08-01\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/tasks",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks"]
            },
            "description": "Expect 400 with a field-level validation error on `title`."
          }
        },
        {
          "name": "Create Task - Past Due Date (400)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{userToken}}", "type": "string" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Time travel task\",\n  \"description\": \"Due date is in the past\",\n  \"dueDate\": \"2000-01-01\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/tasks",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks"]
            },
            "description": "Expect 400 — `dueDate` must be today or in the future."
          }
        },
        {
          "name": "Get Task - Forbidden As Non-Owner (403)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{otherUserToken}}", "type": "string" }] },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/tasks/{{taskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks", "{{taskId}}"]
            },
            "description": "Uses {{otherUserToken}} (from 'Register Second User') to access a task owned by the first user. Run this before the 'Tasks (as Admin)' folder's delete request, since the task must still exist. Expect 403."
          }
        },
        {
          "name": "Login - Wrong Password (400)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"definitely-wrong\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Expect 400 with a generic authentication failure message."
          }
        }
      ]
    },
    {
      "name": "Tasks (as Admin)",
      "item": [
        {
          "name": "List All Tasks (Admin)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/tasks?page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" }
              ]
            },
            "description": "Admins see every user's tasks, not just their own."
          }
        },
        {
          "name": "Filter Tasks by Owner (Admin)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/tasks?ownerId=1&page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks"],
              "query": [
                { "key": "ownerId", "value": "1" },
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" }
              ]
            },
            "description": "Only Admins can use `ownerId` to view a specific user's tasks — for a regular user this param is ignored and their own id is forced instead. Replace `1` with a real user id from your database if it doesn't match."
          }
        },
        {
          "name": "Get Any Task (Admin)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/tasks/{{taskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks", "{{taskId}}"]
            },
            "description": "Admins can view any task regardless of owner."
          }
        },
        {
          "name": "Update Any Task (Admin)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] },
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Edited by admin\",\n  \"description\": \"Admins can manage any user's task\",\n  \"status\": \"DONE\",\n  \"dueDate\": \"2026-08-10\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/tasks/{{taskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks", "{{taskId}}"]
            },
            "description": "Admins can update any user's task."
          }
        },
        {
          "name": "Delete Any Task (Admin)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] },
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/tasks/{{taskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks", "{{taskId}}"]
            },
            "description": "Admins can delete any user's task."
          }
        }
      ]
    }
  ]
}
